# ─── PlanCraft web — environment variables ───────────────────────────────────
# Copy this file to `.env.local` and fill in real values. `.env.local` is
# gitignored and must never be committed. In production, set these as secrets in
# your host's environment (e.g. Vercel project settings) rather than in a file.

# ─── Supabase (required) ──────────────────────────────────────────────────────
# Public by design — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Bypasses Row Level Security — NEVER prefix with NEXT_PUBLIC and
# never expose it to the client. Required by the webhooks route
# (src/app/api/webhooks/[token]/route.ts); webhooks return HTTP 501 without it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Integrations (optional — each route returns 503 if its key is unset) ──────
# YouTube Data API — used server-side by the playlist import route.
YOUTUBE_API_KEY=your-youtube-api-key

# Tracker.gg public API — used server-side by the tracker-gg integration route.
TRACKER_GG_API_KEY=your-tracker-gg-api-key

# Steam Web API — free, instant: https://steamcommunity.com/dev/apikey
STEAM_API_KEY=your-steam-api-key

# Twitch — used server-side by the twitch live-status route. Register an app at
# https://dev.twitch.tv/console/apps to get a Client ID + Secret (client-credentials
# flow; no user login needed). Both required for the Twitch item to work.
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret

# ─── Reminders (email delivery) ────────────────────────────────────────────────
# Resend API key — used by /api/cron/reminders to email due reminders. Without it
# reminders are still scheduled but stay pending until a provider is set.
RESEND_API_KEY=your-resend-api-key
# From address for reminder emails (must be a verified Resend sender/domain).
EMAIL_FROM=Crecoard <reminders@yourdomain.com>
# Shared secret the reminder scheduler must present (Authorization: Bearer <secret>,
# x-cron-secret header, or ?key=). Set the same value in the pg_cron job / Vercel cron.
CRON_SECRET=generate-a-long-random-string

# ─── Web Push (installed PWA / Android reminders) ──────────────────────────────
# VAPID keys — generate with: npx web-push generate-vapid-keys
# The public key is exposed to the browser to create push subscriptions.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
# Contact URI for the push service (mailto: or https:).
VAPID_SUBJECT=mailto:admin@yourdomain.com
