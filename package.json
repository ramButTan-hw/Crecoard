    "lint": "turbo run lint",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "allowScripts": {
    "electron@33.4.11": true,
    "sharp@0.34.5": true,
    "unrs-resolver@1.12.2": true,
    "electron-winstaller@5.4.0": true
  },
  "dependencies": {
    "supabase": "^2.108.0"
  }
}
